# Marvin Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# Gemini CLI Authentication
# ============================================================================
# Authentication method: oauth (recommended) or api_key
# - oauth: Use your Google Gemini subscription (run: gemini login)
# - api_key: Use API key (Google AI Studio)
#GEMINI_AUTH_METHOD=oauth

# Get your API key from: https://aistudio.google.com/app/apikey
# not needed if you use oauth login w google
# GEMINI_API_KEY=

# Gemini model to use
# Valid options: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.5-flash-lite
#GEMINI_MODEL=gemini-3-flash-preview

# ============================================================================
# Platform Configuration
# ============================================================================
# auto   = Auto-detect platform
# amd64  = x86_64 architecture
# arm64  = ARM64 / Raspberry Pi
#PLATFORM=auto

# ============================================================================
# Web Access Configuration (ttyd & filebrowser)
# ============================================================================
# The port where the web terminal will be accessible on your HOST
#TTYD_PORT=4488

# The port where the file browser will be accessible on your HOST
#FILEBROWSER_PORT=5599

# ============================================================================
# Optional Features
# ============================================================================
# Install Metasploit Framework (requires ~1GB+ extra space)
#INSTALL_METASPLOIT=false

# Enable Chrome/Chromium for browser automation (Playwright MCP)
#ENABLE_CHROME=true

# Enable Caddy reverse proxy (VPS only)
#ENABLE_CADDY=false

# ============================================================================
# WiFi Adapter Configuration (Raspberry Pi / Local Only)
# ============================================================================
# USB WiFi interface name (typically wlan1)
#WIFI_INTERFACE=wlan1

# Enable monitor mode for WiFi adapter
#WIFI_MONITOR_MODE=false

# ============================================================================
# VPS Configuration (Only needed if ENABLE_CADDY=true)
# ============================================================================
# Your domain name
#DOMAIN_NAME=localhost

# Admin email for Let's Encrypt
#ADMIN_EMAIL=admin@example.com

# ============================================================================
# Resource Limits
# ============================================================================
# CPU limit (number of cores)
#CPU_LIMIT=2.0

# Memory limit (g for gigabytes, m for megabytes)
#MEMORY_LIMIT=4g

# ============================================================================
# System Configuration
# ============================================================================
# Timezone (e.g., America/New_York, Europe/London, Asia/Jerusalem)
#TZ=UTC

# ============================================================================
# Optional: Additional API Keys for MCP Servers
# ============================================================================
#HUBSPOT_ACCESS_TOKEN=
