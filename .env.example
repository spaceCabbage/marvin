# Marvin Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# Claude Code Authentication
# ============================================================================
# Authentication method: oauth (recommended) or api_key
# - oauth: Use your Claude Pro/Max subscription (run: claude login)
# - api_key: Use API key (pay-as-you-go billing)
CLAUDE_AUTH_METHOD=oauth

# Only needed if using api_key method
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model to use (oauth uses your plan's model automatically)
ANTHROPIC_MODEL=claude-opus-4-5-20251101

# ============================================================================
# Platform Configuration
# ============================================================================
# auto   = Auto-detect platform
# amd64  = x86_64 architecture
# arm64  = ARM64 / Raspberry Pi
PLATFORM=auto

# ============================================================================
# Optional Features
# ============================================================================
# Install Metasploit Framework (requires ~1GB+ extra space)
INSTALL_METASPLOIT=false

# Enable Chrome/Chromium for browser automation (Playwright MCP)
ENABLE_CHROME=false

# Enable Caddy reverse proxy (VPS only)
ENABLE_CADDY=false

# ============================================================================
# WiFi Adapter Configuration (Raspberry Pi / Local Only)
# ============================================================================
# USB WiFi interface name (typically wlan1)
WIFI_INTERFACE=wlan1

# Enable monitor mode for WiFi adapter
WIFI_MONITOR_MODE=false

# ============================================================================
# VPS Configuration (Only needed if ENABLE_CADDY=true)
# ============================================================================
# Your domain name
DOMAIN_NAME=marvin.example.com

# Admin email for Let's Encrypt
ADMIN_EMAIL=admin@example.com

# ============================================================================
# Resource Limits
# ============================================================================
# CPU limit (number of cores)
CPU_LIMIT=2.0

# Memory limit (g for gigabytes, m for megabytes)
MEMORY_LIMIT=4g

# ============================================================================
# System Configuration
# ============================================================================
# Timezone (e.g., America/New_York, Europe/London, UTC)
TZ=UTC

# ============================================================================
# Telegram Bot (Optional)
# ============================================================================
# Create a bot via @BotFather on Telegram to get a token
# Then run: make bot-up
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
# Send /id to the bot to find your ID, then add it here
# Leave empty to allow all users (not recommended)
TELEGRAM_ALLOWED_USERS=

# ============================================================================
# Optional: Additional API Keys for MCP Servers
# ============================================================================
# GitHub Personal Access Token (for GitHub MCP server)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=
