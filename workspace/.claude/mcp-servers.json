{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {},
      "disabled": false,
      "comment": "Persistent knowledge graph memory - CRITICAL for user prefs"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {},
      "disabled": false,
      "comment": "Problem decomposition and reasoning"
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@berthojoris/mcp-sqlite-server", "/workspace/data.db"],
      "env": {},
      "disabled": false,
      "comment": "SQLite database at ~/data.db"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {},
      "disabled": false,
      "comment": "Documentation lookup for libraries/APIs"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {},
      "disabled": false,
      "comment": "Browser automation with headless Chromium"
    },
    "hubspot": {
      "command": "npx",
      "args": ["-y", "@hubspot/mcp-server"],
      "env": {
        "HUBSPOT_ACCESS_TOKEN": "${HUBSPOT_ACCESS_TOKEN}"
      },
      "disabled": true,
      "comment": "HubSpot CRM - Enable by setting HUBSPOT_ACCESS_TOKEN in .env"
    },
    "telegram": {
      "command": "uv",
      "args": [
        "run",
        "--with", "mcp>=1.0.0",
        "--with", "httpx>=0.27",
        "python",
        "/workspace/.claude/telegram-mcp/server.py"
      ],
      "env": {
        "TELEGRAM_API_URL": "http://marvin-telegram:8443"
      },
      "disabled": true,
      "comment": "Enable after running make bot-up. Gives Claude telegram_ask, telegram_send_message, telegram_send_file tools."
    }
  }
}
