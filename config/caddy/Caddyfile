# ClaudeVM Caddyfile - Automatic HTTPS Reverse Proxy
# This configuration provides automatic HTTPS with Let's Encrypt

{
    # Global options
    email {$EMAIL}
    
    # Automatic HTTPS
    auto_https on
}

# Main domain
{$DOMAIN} {
    # Enable automatic HTTPS
    tls {$EMAIL}
    
    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
    
    # Health check endpoint
    handle /health {
        respond "OK" 200
    }
    
    # MCP server proxy (if needed for remote access)
    handle /mcp/* {
        reverse_proxy claudevm-main:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # Default response
    handle {
        respond "ClaudeVM - Access via SSH" 200
    }
    
    # Security headers
    header {
        # Enable HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        
        # Prevent clickjacking
        X-Frame-Options "DENY"
        
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        
        # Enable XSS protection
        X-XSS-Protection "1; mode=block"
        
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # Remove server header
        -Server
    }
}
