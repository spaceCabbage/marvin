# Environment
.env

# Ignore workspace contents (user data)
workspace/*
workspace/.gemini/*

# Keep essential config files
!workspace/GEMINI.md
!workspace/.bashrc
# Keep .gemini directory structure
!workspace/.gemini/
# Keep specific .gemini contents
!workspace/.gemini/skills/
!workspace/.gemini/skills/**
!workspace/.gemini/templates/
!workspace/.gemini/templates/**
!workspace/.gemini/settings.json

# Keep engagements directory structure
!workspace/engagements/
!workspace/engagements/.gitkeep

# Caddy data
config/caddy/data/
config/caddy/config/
