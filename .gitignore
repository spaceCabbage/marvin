# Environment
.env

# Ignore workspace contents (user data)
workspace/*

# Keep essential config files
!workspace/CLAUDE.md
!workspace/.bashrc

# Keep .claude directory structure
!workspace/.claude/
workspace/.claude/*

# Keep specific .claude contents
!workspace/.claude/skills/
!workspace/.claude/skills/**
!workspace/.claude/templates/
!workspace/.claude/templates/**
!workspace/.claude/mcp-servers.json
!workspace/.claude/settings.json
!workspace/.claude/statusline.sh
!workspace/.claude/telegram-mcp/
!workspace/.claude/telegram-mcp/**

# Caddy data
config/caddy/data/
config/caddy/config/
