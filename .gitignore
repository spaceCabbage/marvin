# ClaudeVM .gitignore

# =============================================================================
# Environment and Secrets
# =============================================================================
.env
.env.local
*.key
*.pem
*.crt

# =============================================================================
# Workspace - Home directory that persists in container
# =============================================================================
# Ignore everything in workspace
workspace/**
# Track these specific config files
!workspace/CLAUDE.md
!workspace/.bashrc
!workspace/.claude/
!workspace/.claude/**
!workspace/.claude/skills/**
# Ignore Claude runtime files (after un-ignoring .claude directory)
workspace/.claude/auth.json
workspace/.claude/statsig.json
workspace/.claude/projects
workspace/.claude/.claude-session
workspace/.claude/cache
workspace/.claude/debug
workspace/.claude/file-history
workspace/.claude/shell-snapshots
workspace/.claude/debug
workspace/.claude/statsig
workspace/.claude/plugins
workspace/.claude/todos
workspace/.claude/.credentials.json
workspace/.claude/history.jsonl
workspace/.claude/settings.local.json

# =============================================================================
# Docker
# =============================================================================
*-data/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp

# =============================================================================
# Build Artifacts
# =============================================================================
*.tar.gz
*.zip

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup

# =============================================================================
# Node.js
# =============================================================================
node_modules/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.pytest_cache/
venv/
.venv/

# =============================================================================
# Go
# =============================================================================
*.exe
*.dll
*.dylib

# =============================================================================
# Caddy
# =============================================================================
config/caddy/data/
config/caddy/config/
